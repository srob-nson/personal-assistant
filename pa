#!/usr/bin/env python3

import json
import sys
import subprocess
from pathlib import Path

ASSISTANT_DIR = Path.home() / "homelab/personal-assistant"
PROFILE_FILE = ASSISTANT_DIR / "profile.md"
MEMORY_FILE = ASSISTANT_DIR / "memory.md"

OLLAMA_URL = "http://localhost:11434/api/chat"
OLLAMA_MODEL = "llama3.1:8b"
OLLAMA_TIMEOUT_SECONDS = 120

CODE_KEYWORDS = [
    "code", "script", "bug", "error", "traceback", "repo", "git",
    "diff", "patch", "function", "class", "test", "refactor",
    "shell", "bash", "filesystem", "file", "directory", "readme",
    "agents.md", "dockerfile", "ansible", "sshfs", "logseq plugin"
]


def read_file(path):
    if path.exists():
        return path.read_text(errors="ignore")
    return ""


def build_context(user_prompt):
    profile = read_file(PROFILE_FILE)
    memory = read_file(MEMORY_FILE)

    agents_file = Path.cwd() / "AGENTS.md"
    agents = read_file(agents_file)

    return f"""
You are Sam's local CLI Personal Assistant.

PROFILE:
{profile}

MEMORY:
{memory}

PROJECT CONTEXT:
{agents}

USER PROMPT:
{user_prompt}
""".strip()


def should_use_codex(prompt):
    prompt_lower = prompt.lower()
    return any(word in prompt_lower for word in CODE_KEYWORDS)


def run_codex(prompt):
    print("-> Routed to Codex. Starting coding assistant...\n", flush=True)

    try:
        result = subprocess.run(
            ["codex", prompt],
            text=True
        )
    except FileNotFoundError:
        print("Codex command not found: codex", file=sys.stderr)
        return 127
    except OSError as error:
        print(f"Failed to start Codex: {error}", file=sys.stderr)
        return 1

    return result.returncode


def run_ollama(prompt):
    try:
        import requests
    except ModuleNotFoundError:
        print("Ollama backend requires the Python package 'requests'.", file=sys.stderr)
        return 1

    payload = {
        "model": OLLAMA_MODEL,
        "stream": True,
        "messages": [
            {
                "role": "system",
                "content": "You are a helpful local personal assistant."
            },
            {
                "role": "user",
                "content": prompt
            }
        ]
    }

    print("-> Routed to Ollama. Generating response...\n", flush=True)

    try:
        with requests.post(
            OLLAMA_URL,
            json=payload,
            stream=True,
            timeout=OLLAMA_TIMEOUT_SECONDS,
        ) as response:
            response.raise_for_status()

            for line in response.iter_lines():
                if not line:
                    continue

                chunk = json.loads(line.decode("utf-8"))

                if not isinstance(chunk, dict):
                    print(
                        "Ollama returned malformed stream: expected JSON object with optional message object.",
                        file=sys.stderr,
                    )
                    return 1

                if "message" in chunk:
                    message = chunk["message"]
                    if not isinstance(message, dict):
                        print(
                            "Ollama returned malformed stream: expected JSON object with optional message object.",
                            file=sys.stderr,
                        )
                        return 1

                    if "content" in message:
                        content = message["content"]
                        if not isinstance(content, str):
                            print(
                                "Ollama returned malformed stream: expected JSON object with optional message object.",
                                file=sys.stderr,
                            )
                            return 1
                        print(content, end="", flush=True)

                if chunk.get("done"):
                    print()
                    return 0
    except requests.exceptions.RequestException as error:
        print(f"Ollama request failed: {error}", file=sys.stderr)
        return 1
    except json.JSONDecodeError as error:
        print(f"Ollama returned invalid JSON: {error}", file=sys.stderr)
        return 1

    print("Ollama stream ended before completion.", file=sys.stderr)
    return 1


def print_usage():
    print('Usage: pa [--codex|--ollama] "prompt here"')
    print()
    print("Routes coding-related prompts to Codex and other prompts to Ollama.")
    print("Use --codex or --ollama to force a backend.")


def main():
    if len(sys.argv) < 2:
        print_usage()
        return 1

    if sys.argv[1] in ("-h", "--help"):
        print_usage()
        return 0

    route_override = None
    prompt_args = sys.argv[1:]

    if prompt_args[0] in ("--codex", "--ollama"):
        route_override = prompt_args[0]
        prompt_args = prompt_args[1:]

        if not prompt_args:
            print_usage()
            return 1

    user_prompt = " ".join(prompt_args)
    full_prompt = build_context(user_prompt)

    if route_override == "--codex" or (
        route_override is None and should_use_codex(user_prompt)
    ):
        return run_codex(full_prompt)

    return run_ollama(full_prompt)


if __name__ == "__main__":
    sys.exit(main())
